test:
  $import: ../stdlib/test.vibra
literal-int-arm:
  $test:
    do:
    - $let:
        n: 3
    - $match: $n
      when:
      - case: 1
        do:
        - $test.fail: matched 1
      - case: 3
        do:
        - $test.assert: true
      - case:
          $wildcard: null
        do:
        - $test.fail: fell through to wildcard
literal-string-arm:
  $test:
    do:
    - $let:
        s: b
    - $match: $s
      when:
      - case: a
        do:
        - $test.fail: matched a
      - case: b
        do:
        - $test.assert: true
      - case:
          $wildcard: null
        do:
        - $test.fail: fell through
bool-arm:
  $test:
    do:
    - $let:
        flag: false
    - $match: $flag
      when:
      - case: true
        do:
        - $test.fail: matched true
      - case: false
        do:
        - $test.assert: true
      - case:
          $wildcard: null
        do:
        - $test.fail: fell through bool match
wildcard-catch-all:
  $test:
    do:
    - $let:
        n: 99
    - $match: $n
      when:
      - case: 0
        do:
        - $test.fail: matched 0
      - case:
          $wildcard: null
        do:
        - $test.assert: true
bind-captures-value:
  $test:
    do:
    - $let:
        n: 8
    - $match: $n
      when:
      - case: 7
        do:
        - $test.fail: matched 7
      - case:
          $bind: captured
        do:
        - $match: $captured
          when:
          - case: 8
            do:
            - $test.assert: true
          - case:
              $wildcard: null
            do:
            - $test.fail: wrong captured value
      - case:
          $wildcard: null
        do:
        - $test.fail: fell through to wildcard
