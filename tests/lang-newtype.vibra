test:
  $import: ../stdlib/test.vibra
meters:
  $newtype: $int64
label:
  $newtype: $str
cast-into-newtype:
  $test:
    do:
    - $let:
        d:
          $cast: 10
          into: $meters
    - $match: $d
      when:
      - case:
          $newtype:
            type: $meters
            inner:
              $bind: raw
        do:
        - $match: $raw
          when:
          - case: 10
            do:
            - $test.assert: true
          - case:
              $wildcard: null
            do:
            - $test.fail: wrong inner value
      - case:
          $wildcard: null
        do:
        - $test.fail: expected meters newtype
cast-string-newtype:
  $test:
    do:
    - $let:
        l:
          $cast: north
          into: $label
    - $match: $l
      when:
      - case:
          $newtype:
            type: $label
            inner:
              $bind: raw
        do:
        - $match: $raw
          when:
          - case: north
            do:
            - $test.assert: true
          - case:
              $wildcard: null
            do:
            - $test.fail: wrong inner string
      - case:
          $wildcard: null
        do:
        - $test.fail: expected label newtype
