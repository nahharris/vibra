test:
  $import: ../stdlib/test.vibra
option:
  $import: ../stdlib/option.vibra
some-carries-payload:
  $test:
    do:
    - $let:
        o:
          $option.option.some: 7
    - $match: $o
      when:
      - case:
          $option.option.some:
            $bind: v
        do:
        - $match: $v
          when:
          - case: 7
            do:
            - $test.assert: true
          - case:
              $wildcard: null
            do:
            - $test.fail: wrong some payload
      - case:
          $option.option.none: null
        do:
        - $test.fail: expected some
none-variant:
  $test:
    do:
    - $let:
        present:
          $option.option.some: 1
    - $match: $present
      when:
      - case:
          $option.option.some:
            $bind: _v
        do:
        - $let:
            absent: $option.option.none
        - $match: $absent
          when:
          - case:
              $option.option.some:
                $bind: _x
            do:
            - $test.fail: expected none
          - case:
              $option.option.none: null
            do:
            - $test.assert: true
      - case:
          $option.option.none: null
        do:
        - $test.fail: expected some
