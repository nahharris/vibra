test:
  $import: ../stdlib/test.vibra
signal:
  $enum:
    stop: $void
    go: $int64
opt:
  $enum:
    none: $void
    some: $str
construct-and-match-payload:
  $test:
    do:
    - $let:
        s:
          $signal.go: 3
    - $match: $s
      when:
      - case:
          $signal.go:
            $bind: speed
        do:
        - $match: $speed
          when:
          - case: 3
            do:
            - $test.assert: true
          - case:
              $wildcard: null
            do:
            - $test.fail: wrong payload
      - case:
          $signal.stop: null
        do:
        - $test.fail: expected go
void-variant-constructor:
  $test:
    do:
    - $let:
        s: $signal.stop
    - $match: $s
      when:
      - case:
          $signal.stop: null
        do:
        - $test.assert: true
      - case:
          $signal.go:
            $bind: _speed
        do:
        - $test.fail: expected stop
option-like-some:
  $test:
    do:
    - $let:
        v:
          $opt.some: hi
    - $match: $v
      when:
      - case:
          $opt.some:
            $bind: text
        do:
        - $match: $text
          when:
          - case: hi
            do:
            - $test.assert: true
          - case:
              $wildcard: null
            do:
            - $test.fail: wrong text
      - case:
          $opt.none: null
        do:
        - $test.fail: expected some
option-like-none:
  $test:
    do:
    - $let:
        v: $opt.none
    - $match: $v
      when:
      - case:
          $opt.some:
            $bind: _text
        do:
        - $test.fail: expected none
      - case:
          $opt.none: null
        do:
        - $test.assert: true
