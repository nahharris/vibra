test:
  $import: ../stdlib/test.vibra
result:
  $import: ../stdlib/result.vibra
ok-carries-payload:
  $test:
    do:
    - $let:
        r:
          $result.result.ok: 99
    - $match: $r
      when:
      - case:
          $result.result.ok:
            $bind: v
        do:
        - $match: $v
          when:
          - case: 99
            do:
            - $test.assert: true
          - case:
              $wildcard: null
            do:
            - $test.fail: wrong ok payload
      - case:
          $result.result.err:
            $bind: _e
        do:
        - $test.fail: expected ok
err-carries-payload:
  $test:
    do:
    - $let:
        r:
          $result.result.err: boom
    - $match: $r
      when:
      - case:
          $result.result.ok:
            $bind: _v
        do:
        - $test.fail: expected err
      - case:
          $result.result.err:
            $bind: e
        do:
        - $match: $e
          when:
          - case: boom
            do:
            - $test.assert: true
          - case:
              $wildcard: null
            do:
            - $test.fail: wrong err payload
