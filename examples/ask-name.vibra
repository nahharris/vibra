io:
  $import: ../stdlib/io.vibra
types:
  $import: ../stdlib/types.vibra
main:
  $function:
    args: $void
    return: $void
    do:
      - $io.print: "What is your name? "
      - $let:
          name:
            $io.read-line:
              $types.Fd.FromInt: $io.stdin-fd
      - $io.println: $name
