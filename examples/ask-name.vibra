io:
  $import: ../stdlib/io.vibra
main:
  $function:
    args: $void
    return: $void
    do:
      - $io.print: "What is your name? "
      - $let:
          name-result:
            $io.readln: null
      - $match:
          target: $name-result
          arms:
            ok:
              bind: name
              do:
                - $io.println: $name
            err:
              bind: err
              do:
                - $io.eprintln: "failed to read stdin"
