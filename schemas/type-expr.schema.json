{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibra.dev/schemas/type-expr.schema.json",
  "title": "VibraTypeExpr",
  "description": "JSON encoding of a Vibra type after YAML parse (surrogate for LLM tooling). Generic parameters are declared at module-symbol level via the `=where` annotation; a use site of a generic alias must instantiate via `{ $alias: { tparam: T, ... } }`. Inline generic types are not expressible. Optional values use the tagged generic enum from stdlib/option.vibra; `$option` sugar and `$union` with a direct `$void` member are invalid. `$newtype` defines a nominal wrapper around one inner type and requires explicit `$cast` to cross the boundary. `$policy` defines an unforgeable authority type whose values are injected by the runtime and may only be narrowed. `$grant-token` is an internal compatibility type during migration. `$self` is a reserved type usable only inside an `$interface` body (existential placeholder) or inside a type's `=defs` / `=impl` annotation (resolves to the enclosing type).",
  "oneOf": [
    {
      "type": "string",
      "enum": [
        "$int8",
        "$int16",
        "$int32",
        "$int64",
        "$uint8",
        "$uint16",
        "$uint32",
        "$uint64",
        "$float32",
        "$float64",
        "$bool",
        "$void",
        "$str",
        "$grant-token",
        "$self"
      ]
    },
    {
      "type": "object",
      "required": ["$literal"],
      "additionalProperties": false,
      "properties": { "$literal": { "type": ["string", "number", "boolean"] } }
    },
    {
      "type": "object",
      "required": ["$newtype"],
      "additionalProperties": false,
      "properties": { "$newtype": { "$ref": "#" } }
    },
    {
      "type": "object",
      "required": ["$grant-token"],
      "additionalProperties": false,
      "properties": { "$grant-token": { "type": "null" } }
    },
    {
      "type": "object",
      "required": ["$policy"],
      "additionalProperties": false,
      "properties": { "$policy": { "type": "object" } }
    },
    {
      "type": "object",
      "required": ["$record"],
      "additionalProperties": false,
      "properties": {
        "$record": {
          "type": "object",
          "additionalProperties": { "$ref": "#" }
        }
      }
    },
    {
      "type": "object",
      "required": ["$array"],
      "additionalProperties": false,
      "properties": { "$array": { "$ref": "#" } }
    },
    {
      "type": "object",
      "required": ["$tuple"],
      "additionalProperties": false,
      "properties": {
        "$tuple": { "type": "array", "items": { "$ref": "#" } }
      }
    },
    {
      "type": "object",
      "required": ["$union"],
      "additionalProperties": false,
      "properties": {
        "$union": { "type": "array", "items": { "$ref": "#" }, "minItems": 2 }
      }
    },
    {
      "type": "object",
      "required": ["$enum"],
      "additionalProperties": false,
      "properties": {
        "$enum": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#" }
        }
      }
    },
    {
      "type": "object",
      "required": ["$interface"],
      "additionalProperties": false,
      "properties": {
        "$interface": { "type": "object", "additionalProperties": { "$ref": "#" } }
      }
    },
    {
      "type": "object",
      "required": ["$intersect"],
      "additionalProperties": false,
      "properties": {
        "$intersect": { "type": "array", "items": { "$ref": "#" }, "minItems": 2 }
      }
    },
    {
      "type": "object",
      "required": ["$fn-type"],
      "additionalProperties": false,
      "properties": {
        "$fn-type": {
          "type": "object",
          "required": ["args", "return"],
          "additionalProperties": false,
          "properties": {
            "args": { "$ref": "#" },
            "return": { "$ref": "#" }
          }
        }
      }
    },
    {
      "type": "object",
      "required": ["$map"],
      "additionalProperties": false,
      "properties": {
        "$map": {
          "type": "object",
          "required": ["key", "value"],
          "additionalProperties": false,
          "properties": {
            "key": { "$ref": "#" },
            "value": { "$ref": "#" }
          }
        }
      }
    },
    {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "patternProperties": {
        "^\\$[A-Za-z][A-Za-z0-9.\\-]*$": {
          "type": "object",
          "additionalProperties": { "$ref": "#" },
          "description": "Use-site instantiation of a generic type alias: keys are the alias's type-parameter names from its `where` annotation."
        }
      },
      "additionalProperties": false
    }
  ]
}
