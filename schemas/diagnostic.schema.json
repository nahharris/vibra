{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibra.dev/schemas/diagnostic.schema.json",
  "title": "VibraDiagnostic",
  "type": "object",
  "required": ["code", "message", "severity", "span"],
  "additionalProperties": false,
  "properties": {
    "code": {
      "type": "string",
      "description": "Stable error code, e.g. E-YAML-001, E-ONE-002, E-TY-100"
    },
    "message": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["error", "warning", "info", "hint"]
    },
    "span": {
      "type": "object",
      "required": ["uri", "start", "end"],
      "additionalProperties": false,
      "properties": {
        "uri": { "type": "string", "format": "uri" },
        "start": { "$ref": "#/$defs/position" },
        "end": { "$ref": "#/$defs/position" }
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["message", "span"],
        "additionalProperties": false,
        "properties": {
          "message": { "type": "string" },
          "span": {
            "type": "object",
            "required": ["uri", "start", "end"],
            "additionalProperties": false,
            "properties": {
              "uri": { "type": "string", "format": "uri" },
              "start": { "$ref": "#/$defs/position" },
              "end": { "$ref": "#/$defs/position" }
            }
          }
        }
      }
    },
    "fix": {
      "type": "array",
      "description": "RFC 6902 JSON Patch operations",
      "items": { "type": "object" }
    }
  },
  "$defs": {
    "position": {
      "type": "object",
      "required": ["line", "column"],
      "additionalProperties": false,
      "properties": {
        "line": { "type": "integer", "minimum": 0 },
        "column": { "type": "integer", "minimum": 0 },
        "offset": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
